{
  "info": {
    "name": "My Ticket Booking App",
    "description": "Complete API test collection for My Ticket Booking App Microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8080", "type": "string" }
  ],
  "item": [

    {
      "name": "User Service",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Arjun Sharma\",\n  \"email\": \"arjun@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/users"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/users/1"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/users/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Arjun Kumar Sharma\",\n  \"email\": \"arjun@example.com\",\n  \"password\": \"newpassword123\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/users/1"
          }
        }
      ]
    },

    {
      "name": "Train Service",
      "item": [
        {
          "name": "Add Train",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/trains",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainNumber\": \"12626\",\n  \"trainName\": \"Kerala Express\",\n  \"source\": \"New Delhi\",\n  \"destination\": \"Thiruvananthapuram\",\n  \"availableSeats\": 200,\n  \"fare\": 1500.00\n}"
            }
          }
        },
        {
          "name": "Add Another Train",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/trains",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainNumber\": \"12301\",\n  \"trainName\": \"Howrah Rajdhani\",\n  \"source\": \"New Delhi\",\n  \"destination\": \"Howrah\",\n  \"availableSeats\": 300,\n  \"fare\": 2200.00\n}"
            }
          }
        },
        {
          "name": "Get All Trains",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/trains"
          }
        },
        {
          "name": "Get Train By ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/trains/1"
          }
        },
        {
          "name": "Update Train",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/trains/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainNumber\": \"12626\",\n  \"trainName\": \"Kerala Superfast Express\",\n  \"source\": \"New Delhi\",\n  \"destination\": \"Thiruvananthapuram\",\n  \"availableSeats\": 250,\n  \"fare\": 1600.00\n}"
            }
          }
        },
        {
          "name": "Delete Train",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/trains/1"
          }
        }
      ]
    },

    {
      "name": "Booking Service",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/bookings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"trainId\": 1,\n  \"seatsBooked\": 2\n}"
            }
          }
        },
        {
          "name": "Get All Bookings",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/bookings"
          }
        },
        {
          "name": "Get Booking By ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/bookings/1"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/bookings/1/cancel"
          }
        }
      ]
    },

    {
      "name": "Payment Service",
      "item": [
        {
          "name": "Process Payment (UPI)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/payments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": 1,\n  \"amount\": 3000.00,\n  \"paymentMode\": \"UPI\"\n}"
            }
          }
        },
        {
          "name": "Process Payment (Credit Card)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/payments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": 1,\n  \"amount\": 3000.00,\n  \"paymentMode\": \"CREDIT_CARD\"\n}"
            }
          }
        },
        {
          "name": "Get Payment By ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/payments/1"
          }
        },
        {
          "name": "Get Payments By Booking ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/payments/booking/1"
          }
        },
        {
          "name": "Refund Payment",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/payments/1/refund"
          }
        }
      ]
    }
  ]
}
